# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=darkmoorai
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Free APIs (no keys needed for most!)
WIKIPEDIA_USER_AGENT=DarkmoorAI/1.0 (contact@darkmoor.ai)

# Optional: Paid APIs
TAVILY_API_KEY=your-tavily-api-key # Optional, for enhanced search
STRIPE_SECRET_KEY=sk_test_... # For payments
STRIPE_WEBHOOK_SECRET=whsec_...

# Storage
UPLOAD_DIR=./data/uploads
MAX_FILE_SIZE=10485760 # 10MB
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,txt

# Rate Limiting
RATE_LIMIT_WINDOW=60000 # 1 minute
RATE_LIMIT_MAX_REQUESTS=60

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@darkmoor.ai

# Cost Control
DAILY_BUDGET_PER_USER=0.10
MAX_TOKENS_PER_QUERY=4000
WARN_AT_COST=0.01

# Monitoring
SENTRY_DSN=your-sentry-dsn
